{
  "collections": {
    "users": {
      "description": "Stores student and admin profile information, wallet balances, enrolled course IDs, quiz attempts, and completed lectures",
      "fields": {
        "id": "string",
        "name": "string",
        "phone": "string",
        "role": "string",
        "password": "string",
        "walletBalance": "number",
        "enrolledCourseIds": "array<string>",
        "completedLectures": "array<string>",
        "quizAttempts": "map"
      }
    },
    "courses": {
      "description": "Stores the lists of educational courses, chapters, lectures, quizzes, and reviews",
      "fields": {
        "id": "string",
        "title": "string",
        "category": "string",
        "gradeLevel": "string",
        "price": "number",
        "image": "string",
        "lecturesCount": "number",
        "rating": "number",
        "teacher": "map",
        "lectures": "array<map>",
        "reviews": "array<map>"
      }
    },
    "pending_payments": {
      "description": "Tracks student manual payment transaction request approvals",
      "fields": {
        "id": "string",
        "userId": "string",
        "userName": "string",
        "userPhone": "string",
        "courseId": "string",
        "courseTitle": "string",
        "amount": "number",
        "method": "string",
        "senderPhoneOrRef": "string",
        "status": "string",
        "timestamp": "string"
      }
    },
    "charge_codes": {
